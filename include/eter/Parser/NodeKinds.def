/// \file
/// X-Macro definitions for all AST node kinds produced by the Eter parser.
/// The payload encoding is essential to understand the encoding contract of
/// the `NodePool` class. That is, the `NodePool` must be able to store all node
/// kinds, and it must be able to encode and decode all node kinds. This is the
/// only way to guarantee that the `NodePool` can be serialized and deserialized.
///
/// Usage: define one or more of the macros below before including this file:
///
///   ETER_NODE(X)   any node kind
///   ETER_DECL(X)   declaration-level node (expands to ETER_NODE by default)
///   ETER_STMT(X)   statement-level node   (expands to ETER_NODE by default)
///   ETER_EXPR(X)   expression-level node  (expands to ETER_NODE by default)
///   ETER_TYPE(X)   type-expression node   (expands to ETER_NODE by default)
///   ETER_PAT(X)    pattern node           (expands to ETER_NODE by default)

#ifndef ETER_NODE
#define ETER_NODE(X)
#endif
#ifndef ETER_DECL
#define ETER_DECL(X) ETER_NODE(X)
#endif
#ifndef ETER_STMT
#define ETER_STMT(X) ETER_NODE(X)
#endif
#ifndef ETER_EXPR
#define ETER_EXPR(X) ETER_NODE(X)
#endif
#ifndef ETER_TYPE
#define ETER_TYPE(X) ETER_NODE(X)
#endif
#ifndef ETER_PAT
#define ETER_PAT(X) ETER_NODE(X)
#endif

//===----------------------------------------------------------------------===//
// Special
//===----------------------------------------------------------------------===//

/// Wraps a malformed source region. Always valid to produce during error
/// recovery. Children: none. Payload: 0.
ETER_NODE(Error)

/// Root node for a complete source file.
/// Children: [FileDocComment*, Attribute*, TopLevelDecl*].  Payload: 0.
ETER_NODE(SourceFile)

/// An @-attribute, e.g. @gpu or @import_model("x.onnx").
/// Children: [ArgList?].  Payload: InternedStr (attribute name, without @).
ETER_NODE(Attribute)

/// A list of call or attribute arguments.
/// Children: [Expr*].  Payload: 0.
ETER_NODE(ArgList)

/// An outer doc comment (`/// …`), attached to the declaration it precedes.
/// Children: [].  Payload: InternedStr (raw comment text, including the `///`
/// prefix).
ETER_NODE(DocComment)

/// An inner / file-level doc comment (`//! …`), attached to the enclosing
/// scope (the SourceFile when at the top, eventually a `mod {}` body).
/// Children: [].  Payload: InternedStr (raw comment text, including the `//!`
/// prefix).
ETER_NODE(FileDocComment)

//===----------------------------------------------------------------------===//
// Declarations
//===----------------------------------------------------------------------===//

/// Function declaration: fn [regime] name(ParamList) [: ReturnType] BlockExpr
/// Children: [DocComment*, Attribute*, ParamList, ReturnType?, BlockExpr].
/// Payload:  makePayload(name, returnRegime).
ETER_DECL(FnDecl)

/// Struct declaration: struct Name { StructField* }
/// Children: [DocComment*, Attribute*, StructField*].  Payload: InternedStr (name).
ETER_DECL(StructDecl)

/// Enum declaration: enum Name { EnumVariant* }
/// Children: [DocComment*, Attribute*, EnumVariant*].  Payload: InternedStr (name).
ETER_DECL(EnumDecl)

/// Inline module declaration: mod name { TopLevelDecl* }
/// Children: [DocComment*, Attribute*, TopLevelDecl*].  Payload: InternedStr (name).
ETER_DECL(ModDecl)

/// File-based module declaration: mod name ;
/// The Driver resolves this to a source file (foo.eter or foo/mod.et) and
/// parses it as a separate pack unit. Resolved files share the same
/// StringInterner as the root, enabling O(1) cross-file name comparison.
/// Children: [DocComment*, Attribute*].  Payload: InternedStr (module name).
ETER_DECL(ModDeclFile)

/// Use declaration: use path::item [as alias] ;
/// Children: [DocComment*, Attribute*].  Payload: InternedStr (full path string, interned).
ETER_DECL(UseDecl)

/// Constant declaration: const NAME: Type = Expr ;
/// Children: [DocComment*, Attribute*, Type, Expr].  Payload: InternedStr (name).
ETER_DECL(ConstDecl)

/// A struct field with regime: [regime] name: Type
/// Children: [Type].  Payload: makePayload(name, regime).
ETER_DECL(StructField)

/// Unit enum variant:  VariantName
/// Children: [].  Payload: InternedStr (name).
ETER_DECL(EnumVariantUnit)

/// Tuple enum variant: VariantName(Type*)
/// Children: [Type*].  Payload: InternedStr (name).
ETER_DECL(EnumVariantTuple)

/// Struct enum variant: VariantName { StructField* }
/// Children: [StructField*].  Payload: InternedStr (name).
ETER_DECL(EnumVariantStruct)

/// A formal parameter: [regime] name: Type
/// Children: [Type].  Payload: makePayload(name, regime).
ETER_DECL(Param)

/// The parenthesised list of parameters in a function declaration.
/// Children: [Param*].  Payload: 0.
ETER_DECL(ParamList)

//===----------------------------------------------------------------------===//
// Statements
//===----------------------------------------------------------------------===//

/// Let binding: let [regime] name [: Type] [= Expr] ;
/// Children: [Type?, Expr?].  Payload: makePayload(name, regime).
ETER_STMT(LetStmt)

/// An expression used as a statement (must end with ';' in Eter).
/// Children: [Expr].  Payload: 0.
ETER_STMT(ExprStmt)

/// Return statement: ret [Expr] ;
/// Children: [Expr?].  Payload: 0.
ETER_STMT(RetStmt)

/// For loop: for name in Expr BlockExpr
/// Children: [Expr (iterable), BlockExpr].  Payload: InternedStr (loop var).
ETER_STMT(ForStmt)

/// While loop: while Expr BlockExpr
/// Children: [Expr (condition), BlockExpr].  Payload: 0.
ETER_STMT(WhileStmt)

/// break ;
/// Children: [].  Payload: 0.
ETER_STMT(BreakStmt)

/// continue ;
/// Children: [].  Payload: 0.
ETER_STMT(ContinueStmt)

//===----------------------------------------------------------------------===//
// Expressions
//
// Note: if / match / block are expressions (they yield a value). When used as
// statements they are wrapped in ExprStmt.
//===----------------------------------------------------------------------===//

/// Block expression: { Stmt* [Expr] }
/// Children: [Stmt*, Expr?].  Payload: 0.
ETER_EXPR(BlockExpr)

/// If expression: if Expr BlockExpr [else (BlockExpr | IfExpr)]
/// Children: [Expr (cond), BlockExpr (then), BlockExpr|IfExpr? (else)].
/// Payload: 0.
ETER_EXPR(IfExpr)

/// Match expression: match Expr { MatchArm* }
/// Children: [Expr (scrutinee), MatchArm*].  Payload: 0.
ETER_EXPR(MatchExpr)

/// A match arm: Pat => Expr
/// Children: [Pat, Expr].  Payload: 0.
ETER_NODE(MatchArm)

/// Binary expression: Expr op Expr
/// Children: [Expr (lhs), Expr (rhs)].
/// Payload: makeOpPayload(static_cast<uint16_t>(Token::Kind)).
ETER_EXPR(BinaryExpr)

/// Unary prefix expression: op Expr
/// Covers: arithmetic negation (-), logical not (!), and projection creation
/// (&expr — taking a projection of a Mut value, the rhs use of &).
/// Children: [Expr].
/// Payload: makeOpPayload(static_cast<uint16_t>(Token::Kind)).
ETER_EXPR(UnaryExpr)

/// Projection assignment: &lhs = rhs
/// Write a value through a projection variable or projected field path.
/// Semantically distinct from a regular assignment (BinaryExpr with op=eq).
/// Children: [Expr (projection target), Expr (rhs)].  Payload: 0.
ETER_EXPR(ProjAssignExpr)

/// Function or method call: Expr ( ArgList )
/// Children: [Expr (callee), ArgList].  Payload: 0.
ETER_EXPR(CallExpr)

/// Index expression: Expr [ Expr ]
/// Children: [Expr (base), Expr (index)].  Payload: 0.
ETER_EXPR(IndexExpr)

/// Field access: Expr . name
/// Children: [Expr (base)].  Payload: InternedStr (field name).
ETER_EXPR(FieldExpr)

/// Struct literal: Name { FieldInit* }
/// Children: [FieldInit*].  Payload: InternedStr (struct name).
ETER_EXPR(StructLitExpr)

/// Array literal: [ Expr* ]
/// Children: [Expr*].  Payload: 0.
ETER_EXPR(ArrayLitExpr)

/// A field initialiser inside a struct literal: name : Expr (or shorthand).
/// Children: [Expr].  Payload: InternedStr (field name).
ETER_NODE(FieldInit)

/// Identifier reference: name
/// Children: [].  Payload: InternedStr (name).
ETER_EXPR(IdentExpr)

/// Literal value: integer, float, boolean, string, or character.
/// Children: [].  Payload: InternedStr (literal text as it appears in source).
ETER_EXPR(LitExpr)

/// Error-propagation operator: Expr ?
/// Children: [Expr].  Payload: 0.
ETER_EXPR(PropagateExpr)

//===----------------------------------------------------------------------===//
// Types
//===----------------------------------------------------------------------===//

/// A named type: i32, f32, Point (no generics in v0.1).
/// Children: [].  Payload: InternedStr (type name).
ETER_TYPE(NamedType)

/// Array type: [ Type ; Expr ]
/// Children: [Type, Expr (size)].  Payload: 0.
ETER_TYPE(ArrayType)

/// Type with address-space attribute: Type @qualifier
/// e.g. [f32] @global,  Tensor @shared
/// Children: [Type].  Payload: InternedStr (qualifier name, e.g. "global").
ETER_TYPE(AttrType)

//===----------------------------------------------------------------------===//
// Patterns (for match arms)
//===----------------------------------------------------------------------===//

/// Wildcard pattern: _
/// Children: [].  Payload: 0.
ETER_PAT(WildcardPat)

/// Literal pattern: 42, true, "hello", 'x'
/// Children: [].  Payload: InternedStr (literal text).
ETER_PAT(LiteralPat)

/// Binding pattern: name  (binds the scrutinee to a local name)
/// Children: [].  Payload: makePayload(name, regime).
ETER_PAT(IdentPat)

/// Struct pattern: Name { field: Pat, … }
/// Children: [FieldPat*].  Payload: InternedStr (struct or variant name).
ETER_PAT(StructPat)

/// Tuple / enum-variant pattern: Name(Pat*)
/// Children: [Pat*].  Payload: InternedStr (variant name, or NullStr for
/// anonymous tuples).
ETER_PAT(TuplePat)

/// A single field binding inside a struct pattern: name [: Pat]
/// Children: [Pat?].  Payload: InternedStr (field name).
ETER_NODE(FieldPat)

//===----------------------------------------------------------------------===//
// Macro clean-up
//===----------------------------------------------------------------------===//
#undef ETER_NODE
#undef ETER_DECL
#undef ETER_STMT
#undef ETER_EXPR
#undef ETER_TYPE
#undef ETER_PAT
