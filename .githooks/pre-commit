set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files=()
while IFS= read -r file; do
  [[ -n "$file" ]] || continue
  staged_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ ${#staged_files[@]} -eq 0 ]]; then
  exit 0
fi

echo "[eter] Running pre-commit checks..."

# Run git diff --cached --check without invoking the pager. If there are
# problems, print them and fail the hook.
if ! output=$(git --no-pager diff --cached --check 2>&1); then
  printf '%s\n' "$output"
  exit 1
fi

has_cpp=false
has_source=false
for file in "${staged_files[@]}"; do
  [[ -f "$file" ]] || continue
  case "$file" in
    *.c|*.cc|*.cpp|*.cxx|*.h|*.hh|*.hpp|*.hxx) has_cpp=true ;;
  esac
  case "$file" in
    *.c|*.cc|*.cpp|*.cxx) has_source=true ;;
  esac
done

if $has_cpp; then
  echo "[eter] Checking clang-format..."
  if ! ./x check-clang-format HEAD; then
    echo "[eter] Run: ./x clang-format HEAD  to fix formatting." >&2
    exit 1
  fi
fi

if $has_source; then
  if [[ ! -f build/compile_commands.json ]]; then
    echo "[eter] error: build/compile_commands.json was not found." >&2
    echo "[eter] Run: ./x config" >&2
    exit 1
  fi

  echo "[eter] Checking clang-tidy..."
  if ! ./x clang-tidy HEAD; then
    exit 1
  fi
fi

echo "[eter] All pre-commit checks passed."
